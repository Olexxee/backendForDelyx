            "url": {
              "raw": "{{baseUrl}}/api/feed/posts/{{postId}}/reactions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "feed", "posts", "{{postId}}", "reactions"]
            }
          }
        },
        {
          "name": "React to Comment",
