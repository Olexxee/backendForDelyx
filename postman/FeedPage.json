            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/feed/comments/{{commentId}}/reactions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "feed", "comments", "{{commentId}}", "reactions"]
            }
          }
        },
        {
          "name": "Remove Reaction from Comment",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/feed/comments/{{commentId}}/reactions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "feed", "comments", "{{commentId}}", "reactions"]
